APP_ENV=production
APP_NAME=RAG Console
APP_DOMAIN=rag.atharvaai.com
API_BASE_URL=https://rag.atharvaai.com
WEB_BASE_URL=https://rag.atharvaai.com
API_PORT=8000
WEB_PORT=3000

POSTGRES_USER=rag
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=rag_console
DATABASE_URL=postgresql+psycopg2://rag:replace-with-a-long-random-password@postgres:5432/rag_console
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=replace-with-a-fernet-key
SESSION_COOKIE_NAME=rag_console_session
SESSION_TTL_MINUTES=10080
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
ALLOW_DEV_AUTH_CODES=false
CORS_ORIGINS=https://rag.atharvaai.com

S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_PUBLIC_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET=replace-with-your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
MAX_UPLOAD_BYTES=104857600
MULTIPART_THRESHOLD_BYTES=26214400

EMAIL_BACKEND=ses
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=RAG Console <no-reply@example.com>
AWS_REGION=us-east-1

DETERMINISTIC_EMBEDDING_DIMENSION=384
ENABLE_DEV_EMBEDDING_PROVIDER=false
ENABLE_LLM_CONTENT_PROCESSING=false
RATE_LIMIT_PER_MINUTE=120
